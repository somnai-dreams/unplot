{
  "name": "unplot",
  "version": "0.0.1",
  "module": "src/index.ts",
  "type": "module",
  "license": "MIT",
  "description": "Read curves off a vector PDF — calibrated data + QA. Browser/TS port of the unplot Python package.",
  "scripts": {
    "test": "bun test",
    "typecheck": "tsc --noEmit && tsc --noEmit -p demo/tsconfig.json",
    "lint": "oxlint --type-aware src test demo/main.ts build-demo.ts",
    "knip": "knip-bun",
    "check": "bun run typecheck && bun run lint && bun run knip",
    "build:demo": "bun build-demo.ts",
    "serve:demo": "python3 demo/serve.py"
  },
  "dependencies": {
    "pdfjs-dist": "^4.10.38"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "knip": "^6.20.0",
    "oxlint": "^1.71.0",
    "oxlint-tsgolint": "^0.23.0",
    "typescript": "^6.0.3"
  }
}
